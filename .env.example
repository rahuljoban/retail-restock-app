# Supabase PostgreSQL Database

# Option 1: Session Pooler (port 5432) — recommended for traditional backends
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres

# Option 2: Transaction Pooler (port 6543) — for serverless/edge functions
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres

# Optional: Future env vars
# SECRET_KEY=your-secret-key
# DEBUG=True